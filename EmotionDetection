import os
import numpy as np

def load_model_weights(file_path):
    if os.path.exists(file_path):
        print(f"Loading model weights from {file_path}...")
        return np.load(file_path, allow_pickle=True).item()
    else:
        print(f"File {file_path} not found. Using random placeholder weights.")
        W = np.random.normal(size=(48 * 48, 7))
        b = np.zeros(7)
        return {'W': W, 'b': b}
# Softmax function to predict probabilities
def softmax(x):
    e_x = np.exp(x - np.max(x))
    return e_x / e_x.sum(axis=0)
# Predict emotion from features
def predict_emotion(features, model_weights):
    logits = np.dot(features, model_weights['W']) + model_weights['b']
    return softmax(logits)
